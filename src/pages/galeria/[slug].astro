---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import CartaoPeca from '../../components/CartaoPeca.astro';
import { pilares, marca, caminho } from '../../data/site';

export async function getStaticPaths() {
  const pecas = await getCollection('pecas');
  return pecas.map((peca) => ({
    params: { slug: peca.id },
    props: { peca },
  }));
}

const { peca } = Astro.props;
const { Content } = await render(peca);
const pilar = pilares.find((p) => p.id === peca.data.categoria);
const dataFormatada = peca.data.data.toLocaleDateString('pt-BR', {
  month: 'long',
  year: 'numeric',
});

// outras peças: mesma categoria primeiro, depois as demais (até 3)
const todas = (await getCollection('pecas')).filter((p) => p.id !== peca.id);
const relacionadas = [
  ...todas.filter((p) => p.data.categoria === peca.data.categoria),
  ...todas.filter((p) => p.data.categoria !== peca.data.categoria),
].slice(0, 3);

const whatsappPeca = `${marca.whatsapp}?text=${encodeURIComponent(
  `Olá! Vi a peça "${peca.data.titulo}" no site da Yada e gostaria de saber mais.`
)}`;

const esquema = {
  '@context': 'https://schema.org',
  '@type': 'VisualArtwork',
  name: peca.data.titulo,
  description: peca.data.descricao,
  artform: 'Cerâmica',
  artMedium: 'Argila',
  ...(peca.data.tecnica ? { artworkSurface: peca.data.tecnica } : {}),
  creator: { '@type': 'Organization', name: marca.nome },
};
---

<Base titulo={peca.data.titulo} descricao={peca.data.descricao} esquema={esquema}>
  <section class="secao">
    <div class="contentor">
      <nav class="migalhas" aria-label="Você está em">
        <a href={caminho('/galeria/')}>Galeria</a>
        <span aria-hidden="true">/</span>
        <a href={caminho(`/galeria/#${peca.data.categoria}`)}>{pilar?.curto}</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{peca.data.titulo}</span>
      </nav>

      <div class="peca">
        <div class="imagens">
          {
            peca.data.imagens.map((imagem, i) => (
              <Image
                src={imagem}
                alt={`${peca.data.titulo} — foto ${i + 1}`}
                width={880}
                height={1100}
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            ))
          }
        </div>

        <div class="detalhes">
          <p class="rotulo">{pilar?.titulo}</p>
          <h1>{peca.data.titulo}</h1>
          <p class="texto-suave resumo">{peca.data.descricao}</p>

          <dl class="ficha">
            {
              peca.data.tecnica && (
                <>
                  <dt>Técnica</dt>
                  <dd>{peca.data.tecnica}</dd>
                </>
              )
            }
            <dt>Criada em</dt>
            <dd>{dataFormatada}</dd>
          </dl>

          <div class="historia">
            <h2>A história desta peça</h2>
            <Content />
          </div>

          <div class="acoes">
            <a class="botao botao-cheio" href={whatsappPeca} target="_blank" rel="noopener">
              Perguntar sobre esta peça
            </a>
            <a class="botao" href={caminho('/encomendas/')}>Como encomendar</a>
          </div>
        </div>
      </div>

      {
        relacionadas.length > 0 && (
          <aside class="outras">
            <h2 class="revela">Outras peças</h2>
            <div class="grade-outras">
              {relacionadas.map((outra) => (
                <div class="revela">
                  <CartaoPeca peca={outra} />
                </div>
              ))}
            </div>
          </aside>
        )
      }
    </div>
  </section>
</Base>

<style>
  .migalhas {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--cor-tinta-suave);
    margin-bottom: 2.2rem;
  }

  .migalhas a {
    text-decoration: none;
    color: var(--cor-tinta-suave);
    text-transform: uppercase;
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
  }

  .migalhas a:hover {
    color: var(--cor-destaque);
  }

  .migalhas span[aria-current] {
    font-weight: 600;
    color: var(--cor-tinta);
  }

  .peca {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .imagens {
    display: grid;
    gap: 1.25rem;
  }

  .imagens img {
    width: 100%;
    background: var(--cor-fundo-alt);
  }

  h1 {
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    margin-top: 0.3rem;
  }

  .resumo {
    margin-top: 0.9rem;
    font-size: 1.05rem;
  }

  .ficha {
    margin-top: 2rem;
    border-top: 1px solid var(--cor-linha);
    font-size: 0.95rem;
  }

  .ficha dt {
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cor-tinta-suave);
    padding-top: 0.9rem;
  }

  .ficha dd {
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--cor-linha);
  }

  .historia {
    margin-top: 2.5rem;
  }

  .historia h2 {
    font-size: 1.5rem;
    margin-bottom: 0.8rem;
  }

  .historia :global(p + p) {
    margin-top: 0.9em;
  }

  .acoes {
    margin-top: 2.5rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .outras {
    margin-top: var(--espaco-secao);
    padding-top: 3rem;
    border-top: 1px solid var(--cor-linha);
  }

  .outras h2 {
    margin-bottom: 2rem;
  }

  .grade-outras {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem 1.75rem;
  }

  @media (max-width: 52rem) {
    .peca {
      grid-template-columns: 1fr;
    }

    .grade-outras {
      grid-template-columns: 1fr;
    }
  }
</style>
