---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { pilares, marca, caminho } from '../../data/site';

export async function getStaticPaths() {
  const pecas = await getCollection('pecas');
  return pecas.map((peca) => ({
    params: { slug: peca.id },
    props: { peca },
  }));
}

const { peca } = Astro.props;
const { Content } = await render(peca);
const pilar = pilares.find((p) => p.id === peca.data.categoria);
const dataFormatada = peca.data.data.toLocaleDateString('pt-BR', {
  month: 'long',
  year: 'numeric',
});
---

<Base titulo={peca.data.titulo} descricao={peca.data.descricao}>
  <section class="secao">
    <div class="contentor">
      <a class="voltar" href={caminho('/galeria/')}>← Voltar à galeria</a>

      <div class="peca">
        <div class="imagens">
          {
            peca.data.imagens.map((imagem, i) => (
              <Image
                src={imagem}
                alt={`${peca.data.titulo} — foto ${i + 1}`}
                width={880}
                height={1100}
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            ))
          }
        </div>

        <div class="detalhes">
          <p class="rotulo">{pilar?.titulo}</p>
          <h1>{peca.data.titulo}</h1>
          <p class="texto-suave resumo">{peca.data.descricao}</p>

          <dl class="ficha">
            {
              peca.data.tecnica && (
                <>
                  <dt>Técnica</dt>
                  <dd>{peca.data.tecnica}</dd>
                </>
              )
            }
            <dt>Criada em</dt>
            <dd>{dataFormatada}</dd>
          </dl>

          <div class="historia">
            <h2>A história desta peça</h2>
            <Content />
          </div>

          <div class="acoes">
            <a class="botao botao-cheio" href={marca.whatsapp} target="_blank" rel="noopener">
              Perguntar sobre esta peça
            </a>
            <a class="botao" href={caminho('/encomendas/')}>Como encomendar</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .voltar {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--cor-tinta-suave);
    margin-bottom: 2.2rem;
  }

  .peca {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .imagens {
    display: grid;
    gap: 1.25rem;
  }

  .imagens img {
    width: 100%;
    background: var(--cor-fundo-alt);
  }

  h1 {
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    margin-top: 0.3rem;
  }

  .resumo {
    margin-top: 0.9rem;
    font-size: 1.05rem;
  }

  .ficha {
    margin-top: 2rem;
    border-top: 1px solid var(--cor-linha);
    font-size: 0.95rem;
  }

  .ficha dt {
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cor-tinta-suave);
    padding-top: 0.9rem;
  }

  .ficha dd {
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--cor-linha);
  }

  .historia {
    margin-top: 2.5rem;
  }

  .historia h2 {
    font-size: 1.5rem;
    margin-bottom: 0.8rem;
  }

  .historia :global(p + p) {
    margin-top: 0.9em;
  }

  .acoes {
    margin-top: 2.5rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 52rem) {
    .peca {
      grid-template-columns: 1fr;
    }
  }
</style>
