---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CartaoPeca from '../../components/CartaoPeca.astro';
import { pilares } from '../../data/site';

const pecas = (await getCollection('pecas')).sort(
  (a, b) => b.data.data.valueOf() - a.data.data.valueOf()
);

const contagem = (id: string) => pecas.filter((p) => p.data.categoria === id).length;

// só exibe filtros de categorias que têm peças (e só se houver mais de uma)
const pilaresComPecas = pilares.filter((pilar) => contagem(pilar.id) > 0);
const mostrarFiltros = pilaresComPecas.length > 1;
---

<Base
  titulo="Galeria"
  descricao="As peças da Yada: esculturas, utilitários de mesa e objetos para o ambiente — cerâmica feita à mão."
>
  <section class="secao">
    <div class="contentor">
      <span class="rotulo">Galeria</span>
      <h1>As peças</h1>
      <p class="texto-suave texto-medida intro">
        Cada peça nasce de revelação e é feita à mão, do preparo do barro à
        queima. Toque em uma peça para conhecer a história por trás dela.
      </p>

      {
        mostrarFiltros && (
          <div class="filtros" role="group" aria-label="Filtrar por categoria">
            <button class="filtro" data-filtro="todas" aria-pressed="true">
              Todas <span class="conta">{pecas.length}</span>
            </button>
            {pilaresComPecas.map((pilar) => (
              <button class="filtro" data-filtro={pilar.id} aria-pressed="false">
                {pilar.curto} <span class="conta">{contagem(pilar.id)}</span>
              </button>
            ))}
          </div>
        )
      }

      <div class="grade-pecas">
        {
          pecas.map((peca) => (
            <div class="revela">
              <CartaoPeca peca={peca} />
            </div>
          ))
        }
      </div>

      <p class="vazio texto-suave" hidden>
        Nenhuma peça nesta categoria por enquanto — novas criações estão a
        caminho.
      </p>
    </div>
  </section>
</Base>

<script>
  // Filtro por categoria, refletido no #hash da URL (compartilhável e com
  // botão voltar). Sem JS, todas as peças ficam visíveis.
  function iniciarFiltros() {
    const botoes = document.querySelectorAll<HTMLButtonElement>('.filtro');
    if (!botoes.length) return;
    const cartoes = document.querySelectorAll<HTMLElement>('[data-categoria]');
    const vazio = document.querySelector<HTMLElement>('.vazio');

    function aplicar(filtro: string) {
      let visiveis = 0;
      botoes.forEach((b) =>
        b.setAttribute('aria-pressed', String(b.dataset.filtro === filtro))
      );
      cartoes.forEach((cartao) => {
        const mostrar = filtro === 'todas' || cartao.dataset.categoria === filtro;
        const bloco = cartao.closest<HTMLElement>('.revela') ?? cartao;
        bloco.style.display = mostrar ? '' : 'none';
        if (mostrar) visiveis++;
      });
      if (vazio) vazio.hidden = visiveis > 0;
    }

    function doHash() {
      const alvo = location.hash.replace('#', '');
      const valido = Array.from(botoes).some((b) => b.dataset.filtro === alvo);
      aplicar(valido ? alvo : 'todas');
    }

    botoes.forEach((botao) => {
      botao.addEventListener('click', () => {
        const filtro = botao.dataset.filtro ?? 'todas';
        history.replaceState(null, '', filtro === 'todas' ? '#' : `#${filtro}`);
        aplicar(filtro);
      });
    });

    window.addEventListener('hashchange', doHash);
    doHash();
  }

  document.addEventListener('astro:page-load', iniciarFiltros);
</script>

<style>
  .intro {
    margin-top: 1rem;
  }

  .filtros {
    margin-block: 2.2rem 2.5rem;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .filtro {
    font-family: var(--fonte-texto);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cor-tinta-suave);
    background: none;
    border: 1px solid var(--cor-linha);
    border-radius: 99px;
    padding: 0.5rem 1.3rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filtro:hover {
    border-color: var(--cor-tinta);
    color: var(--cor-tinta);
  }

  .filtro[aria-pressed='true'] {
    background: var(--cor-tinta);
    border-color: var(--cor-tinta);
    color: var(--cor-fundo);
  }

  .conta {
    opacity: 0.55;
    margin-left: 0.2rem;
    font-variant-numeric: tabular-nums;
  }

  .grade-pecas {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem 1.75rem;
  }

  .vazio {
    margin-top: 2rem;
    font-style: italic;
  }

  @media (max-width: 46rem) {
    .grade-pecas {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 46rem) and (max-width: 64rem) {
    .grade-pecas {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
