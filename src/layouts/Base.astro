---
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/500-italic.css';
import '@fontsource/karla/400.css';
import '@fontsource/karla/600.css';
import '../styles/global.css';

import Cabecalho from '../components/Cabecalho.astro';
import Rodape from '../components/Rodape.astro';
import { marca } from '../data/site';

interface Props {
  titulo: string;
  descricao?: string;
}

const { titulo, descricao = marca.descricao } = Astro.props;
const tituloCompleto =
  titulo === marca.nome ? `${marca.nome} — ${marca.slogan}` : `${titulo} · ${marca.nome}`;
const canonica = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{tituloCompleto}</title>
    <meta name="description" content={descricao} />
    <link rel="canonical" href={canonica} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <link rel="sitemap" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/sitemap-index.xml`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={marca.nome} />
    <meta property="og:title" content={tituloCompleto} />
    <meta property="og:description" content={descricao} />
    <meta property="og:url" content={canonica} />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary" />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <Cabecalho />
    <main id="conteudo">
      <slot />
    </main>
    <Rodape />
  </body>
</html>

<style>
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
</style>
