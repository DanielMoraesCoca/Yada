---
/**
 * Marca gráfica da Yada, recriada em código a partir do logotipo oficial:
 * "YADA" em serifa com os "A" sem travessão (renderizados como Λ) e o
 * laço infinito em fita desenhada à mão. Quando o arquivo vetorial
 * oficial estiver disponível, basta substituir este componente.
 */
import { lacoPath } from '../data/laco';

interface Props {
  tamanho?: 'normal' | 'grande';
}
const { tamanho = 'normal' } = Astro.props;
---

<span class:list={['marca', tamanho]}>
  <span class="palavra" aria-hidden="true">Y&Lambda;D&Lambda;</span>
  <span class="leitura">YADA</span>
  <svg class="laco" viewBox="0 0 128 52" aria-hidden="true">
    <path d={lacoPath} fill="currentColor"></path>
  </svg>
</span>

<style>
  .marca {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.12em;
    color: inherit;
    line-height: 1;
  }

  .palavra {
    font-family: var(--fonte-titulo);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-indent: 0.14em; /* compensa o letter-spacing do último caractere */
    font-size: 1.5rem;
  }

  /* texto real para leitores de tela e cópia (o Λ é só visual) */
  .leitura {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .laco {
    width: 2.6em;
    opacity: 0.92;
  }

  .grande .palavra {
    font-size: clamp(3rem, 9vw, 5.5rem);
  }

  .grande .laco {
    width: 3.2em;
  }
</style>
